# Sell to Grand — copy to .env.local and fill in.
# Public site only needs these two (safe to expose; RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://nzaswwzghwmpbclioxah.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Admin — server-only.
# SUPABASE_SECRET_KEY=   # service_role secret from Supabase → Settings → API
# ADMIN_PASSWORD=        # password for /admin sign-in

# Lead notifications (optional). Without RESEND_API_KEY, the form still works
# and saves leads; you just won't get the email.
# RESEND_API_KEY=        # from resend.com
# LEAD_NOTIFY_EMAIL=     # where new-lead emails go (defaults to CONTACT_EMAIL)
# LEAD_FROM_EMAIL=       # e.g. "Sell to Grand <leads@selltogrand.com>" (verify the domain in Resend)
# CONTACT_EMAIL=         # fallback notify recipient
